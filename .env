# /.env.example
# System Environment
PORT=8080
RUST_LOG=info,forgepress=debug
SECRET_KEY=generate_a_random_64_character_string_for_production_use

# Database Configurations
# Un-comment the database you want to target (Postgres or SQLite)

# Option A: PostgreSQL
DATABASE_URL=postgres://forge_user:password@localhost:5432/forgepress_db

# Option B: SQLite
#DATABASE_URL=sqlite://content/forgepress.db

# Path Configs
CONTENT_DIR=./content
UPLOAD_DIR=./content/uploads

# File Upload Limits (in bytes, default: 10MB)
MAX_UPLOAD_SIZE=10485760
