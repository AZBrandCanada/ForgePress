{
  "name": "Button",
  "type": "button",
  "category": "Basic Elements",
  "settings": [
    { "key": "bg", "label": "Background Color", "type": "color", "default": "#4f46e5" },
    { "key": "color", "label": "Text Color", "type": "color", "default": "#ffffff" },
    { "key": "radius", "label": "Corner Radius (px)", "type": "range", "min": 0, "max": 50, "step": 1, "default": "6" },
    { "key": "align", "label": "Alignment", "type": "select", "options": [ { "label": "Left", "value": "left" }, { "label": "Center", "value": "center" }, { "label": "Right", "value": "right" } ], "default": "center" },
    { "key": "margin_v", "label": "Vertical Margin (px)", "type": "range", "min": 0, "max": 100, "step": 1, "default": "15" }
  ],
  "data": [
    { "key": "text", "label": "Button Text", "type": "text", "default": "Click Here" },
    { "key": "url", "label": "Link URL", "type": "text", "default": "#" }
  ]
}